#include <stdio.h>

long fact_rec(int n) {
    if (n <= 1) return 1;
    return n * fact_rec(n - 1);
}

int main() {
    int num;
    printf("Enter number: ");
    scanf("%d", &num);
    if (num < 0) {
        printf("Invalid input.\n");
    } else {
        printf("Factorial : %ld\n", fact_rec(num));
    }
    return 0;
}
