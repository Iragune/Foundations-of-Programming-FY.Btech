#include <stdio.h>
#include <string.h>

int main() {
    char s1[100], s2[100], temp[100];
    int choice;

    printf("Enter first string: ");
    scanf("%s", s1);
    printf("Enter second string: ");
    scanf("%s", s2);

    printf("\n--- MENU ---\n");
    printf("1. Length\n2. Copy\n3. Concatenation\n4. Comparison\n5. Reverse\n");
    printf("Enter choice: ");
    scanf("%d", &choice);

    switch (choice) {
        case 1:
            printf("Length of S1: %ld, S2: %ld\n", strlen(s1), strlen(s2));
            break;
        case 2:
            strcpy(temp, s1);
            printf("S1 copied to temp. Temp = %s\n", temp);
            break;
        case 3:
            strcat(s1, s2);
            printf("Concatenated string: %s\n", s1);
            break;
        case 4:
            if (strcmp(s1, s2) == 0) printf("Strings are equal.\n");
            else printf("Strings are not equal.\n");
            break;
        case 5:
            printf("Reversed S1: ");
            for (int i = strlen(s1) - 1; i >= 0; i--) printf("%c", s1[i]);
            printf("\n");
            break;
        default:
            printf("Invalid choice.\n");
    }

    return 0;
}
