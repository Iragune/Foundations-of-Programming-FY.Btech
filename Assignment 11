#include <stdio.h>
#include <math.h>

void check_prime(int n) {
    int f = 0;
    if (n <= 1) f = 1;
    for (int i = 2; i <= n / 2; i++) {
        if (n % i == 0) { f = 1; break; }
    }
    if (f == 0) printf("%d is prime.\n", n);
    else printf("%d is not prime.\n", n);
}

void factorial(int n) {
    unsigned long long f = 1;
    if (n < 0) printf("Error.\n");
    else {
        for (int i = 1; i <= n; i++) f *= i;
        printf("Factorial: %llu\n", f);
    }
}

void prime_factors(int n) {
    printf("Prime factors: ");
    while (n % 2 == 0) { printf("2 "); n /= 2; }
    for (int i = 3; i <= sqrt(n); i += 2) {
        while (n % i == 0) { printf("%d ", i); n /= i; }
    }
    if (n > 2) printf("%d", n);
    printf("\n");
}

int main() {
    int n, choice;
    printf(" 1:Sqrt\n 2:Square\n 3:Cube\n 4:Prime\n 5:Fact\n 6:P-Factors\n");
    printf("Enter number: ");
    scanf("%d", &n);
    printf("Enter choice: ");
    scanf("%d", &choice);


    switch (choice) {
        case 1: printf("Sqrt: %.2f\n", sqrt(n)); break;
        case 2: printf("Square: %d\n", n * n); break;
        case 3: printf("Cube: %d\n", n * n * n); break;
        case 4: check_prime(n); break;
        case 5: factorial(n); break;
        case 6: prime_factors(n); break;
        default: printf("Invalid choice.\n");
    }
    return 0;
}
