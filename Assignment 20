#include <stdio.h>

void swap_value(int a, int b) {
    int temp = a;
    a = b;
    b = temp;
}

void swap_reference(int *x, int *y) {
    int temp = *x;
    *x = *y;
    *y = temp;
}

int main() {
    int n1, n2;

    printf("Enter two numbers: ");
    scanf("%d %d", &n1, &n2);

    printf("\n--- Call by Value ---\n");
    swap_value(n1, n2);
    printf("Swapped without pointers: n1 = %d, n2 = %d\n", n1, n2);

    printf("\n--- Call by Reference ---\n");
    swap_reference(&n1, &n2);
    printf("Swapped with pointers: n1 = %d, n2 = %d\n", n1, n2);

    return 0;
}
