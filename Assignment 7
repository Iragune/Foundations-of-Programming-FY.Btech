#include <stdio.h>

struct student {
    int roll;
    char name[50];
    int marks[3];
    int total;
    float perc;
};

void calculate(struct student *s) {
    s->total = 0;
    for (int i = 0; i < 3; i++) {
        s->total += s->marks[i];
    }
    s->perc = s->total / 3.0;
}

int main() {
    struct student s[50];
    int n;

    printf("Enter number of students: ");
    scanf("%d", &n);

    for (int i = 0; i < n; i++) {
        printf("\nStudent %d Details:\n", i + 1);
        printf("Roll Number: ");
        scanf("%d", &s[i].roll);
        printf("Name: ");
        scanf("%s", s[i].name);
        printf("Marks in 3 subjects: ");
        for (int j = 0; j < 3; j++) {
            scanf("%d", &s[i].marks[j]);
        }
        calculate(&s[i]);
    }

    printf("\n--- Student Results ---\n");
    for (int i = 0; i < n; i++) {
        printf("\nRoll No: %d\n", s[i].roll);
        printf("Name: %s\n", s[i].name);
        printf("Total Marks: %d\n", s[i].total);
        printf("Percentage: %.2f%%\n", s[i].perc);
    }

    return 0;
}
