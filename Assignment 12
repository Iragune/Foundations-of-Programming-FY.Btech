#include <stdio.h>

int find_scd(int a, int b) {
    int min = (a < b) ? a : b;
    for (int i = 2; i <= min; i++) {
        if (a % i == 0 && b % i == 0) return i;
    }
    return -1; 
}

int find_gcd(int a, int b) {
    while (b != 0) {
        int temp = b;
        b = a % b;
        a = temp;
    }
    return a;
}

int main() {
    int n1, n2;
    printf("Enter two numbers: ");
    scanf("%d %d", &n1, &n2);

    int scd = find_scd(n1, n2);
    int gcd = find_gcd(n1, n2);

    if (scd != -1) printf("Smallest Common Divisor: %d\n", scd);
    else printf("No common divisor other than 1.\n");

    printf("Greatest Common Divisor: %d\n", gcd);

    return 0;
}
