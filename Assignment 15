#include <stdio.h>
#include <stdlib.h>
#include <time.h>

int main() {
    int n, i;

    printf("Enter number of random numbers needed: ");
    if (scanf("%d", &n) != 1) return 1;

    srand(time(NULL));

    printf("Pseudo Random Numbers:\n");
    for (i = 0; i < n; i++) {
        printf("%d\n", rand());
    }

    return 0;
}
